# --- Dependencies ---
/vendor/
/node_modules/

# --- Drupal: configuration and sensitive ---
sites/*/settings*.php
!sites/default/settings.ddev.php
sites/*/services*.yml
sites/default/settings.php
sites/default/settings.local.php
sites/default/services.yml
sites/default/services.local.yml

# --- Drupal: user-generated and runtime ---
sites/*/files/
sites/*/private/
sites/simpletest/
sites/default/files/

# --- Drupal: caches and temp (if present at repo root) ---
*.twigcache

# --- Environment and secrets ---
.env
.env.*
!.env.example

# --- IDE and editors ---
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.project
.settings/
.classpath

# --- OS generated ---
# Windows downloaded-file marker (NTFS alternate stream)
*:Zone.Identifier
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Logs and backups ---
*.log
logs/
*.bak
*.backup
*.orig

# --- Database exports and local archives (keep out of git; use object storage or CI artifacts) ---
/*.sql
/*.sql.gz
/*.sql.zip
/db-exports/
Archive.zip
remynd4-current-db*.zip
remynd4-current-db.mysql8-original.zip
remindy4_backup*.sql.gz
db_backup*.sql.gz

# --- PHP ---
.phpunit.result.cache
.php-cs-fixer.cache
coverage/
.phan/

# --- Composer (keep composer.lock committed) ---
# composer.lock is usually committed for applications

# --- DDEV: local / generated (keep .ddev/config.yaml) ---
.ddev/.ssh/
.ddev/.global_commands/
.ddev/docker-compose*.yaml
.ddev/traefik/
.ddev/mailhog/
.ddev/db_snapshots/

# --- Contrib and Composer-installed assets (do not commit) ---
/modules/contrib/
/themes/contrib/
/libraries/
# /core/

# --- Project-specific optional ---
# /INSTALL.txt
# /README.md
# /robots.txt
/example.gitignore