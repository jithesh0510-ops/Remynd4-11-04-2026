<?php

use Drupal\Core\Form\FormStateInterface;

/**
 * Alter Views exposed filter form: convert company entity-reference to a select
 * and show COMPANY NAME instead of email/username.
 */
function coach_company_dropdown_fix_form_views_exposed_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  $view = $form_state->get('view');
  if (!$view) {
    return;
  }

  // Only on /coach view page (avoid breaking other views).
  $display = $view->current_display;
  $path = $view->displayHandlers->get($display)->getOption('path');
  if ($path !== 'coach' && $path !== '/coach') {
    return;
  }

  // Find the exposed filter element key.
  $key = NULL;
  foreach (['company', 'field_company', 'field_company_target_id'] as $candidate) {
    if (isset($form[$candidate]) && is_array($form[$candidate])) {
      $key = $candidate;
      break;
    }
  }
  if (!$key) {
    return;
  }

  // Get distinct referenced company user IDs from coach profiles.
  $conn = \Drupal::database();
  try {
    $ids = $conn->select('profile__field_company', 'fc')
      ->distinct()
      ->fields('fc', ['field_company_target_id'])
      ->execute()
      ->fetchCol();
  }
  catch (\Exception $e) {
    return;
  }

  $ids = array_values(array_unique(array_filter(array_map('intval', $ids))));
  if (!$ids) {
    return;
  }

  $accounts = \Drupal::entityTypeManager()->getStorage('user')->loadMultiple($ids);

  // Build options: key = uid, value = company name label.
  $options = ['' => t('- Any -')];
  foreach ($accounts as $uid => $account) {
    $label = coach_company_dropdown_fix_get_company_label($account);
    if ($label === '' || $label === NULL) {
      $label = $account->getDisplayName();
    }
    $options[$uid] = $label;
  }

  // Sort labels (keep keys).
  $sorted = $options;
  unset($sorted['']);
  natcasesort($sorted);
  $options = ['' => t('- Any -')] + $sorted;

  // Convert to select dropdown.
  $form[$key]['#type'] = 'select';
  $form[$key]['#options'] = $options;
  $form[$key]['#size'] = 1;
  $form[$key]['#multiple'] = FALSE;

  // Remove autocomplete props so it cannot render as textbox.
  unset(
    $form[$key]['#autocomplete_route_name'],
    $form[$key]['#autocomplete_route_parameters'],
    $form[$key]['#selection_settings'],
    $form[$key]['#target_type'],
    $form[$key]['#process']
  );
}

/**
 * Find a "company name" for the company user.
 * Priority:
 *  1) a user field that looks like company name (contains company/org/title/name)
 *  2) a profile of a type that looks like company* and its company/name/title fields
 *  3) fallback: display name
 */
function coach_company_dropdown_fix_get_company_label($account) {
  // 1) Check user fields (avoid the base 'name' and 'mail' fields).
  $label = coach_company_dropdown_fix_find_string_field_value($account, ['company', 'organization', 'organisation', 'org', 'business', 'title', 'name']);
  if ($label) {
    return $label;
  }

  // 2) Check Profile module (company profile fields).
  if (\Drupal::moduleHandler()->moduleExists('profile')) {
    $type_storage = \Drupal::entityTypeManager()->getStorage('profile_type');
    $types = $type_storage->loadMultiple();

    $company_type_ids = [];
    foreach ($types as $type) {
      $tid = $type->id();
      $ltid = strtolower($tid);
      if (strpos($ltid, 'company') !== FALSE || strpos($ltid, 'organisation') !== FALSE || strpos($ltid, 'organization') !== FALSE) {
        $company_type_ids[] = $tid;
      }
    }

    if ($company_type_ids) {
      $profiles = \Drupal::entityTypeManager()->getStorage('profile')->loadByProperties(['uid' => $account->id()]);
      foreach ($profiles as $profile) {
        if (in_array($profile->bundle(), $company_type_ids, TRUE)) {
          $label = coach_company_dropdown_fix_find_string_field_value($profile, ['company', 'organization', 'organisation', 'org', 'business', 'title', 'name']);
          if ($label) {
            return $label;
          }
        }
      }
    }
  }

  // 3) Fallback.
  return $account->getDisplayName();
}

/**
 * Scan an entity's fields and return the first non-empty string-ish value
 * whose field name contains any of the needles. Avoid returning emails.
 */
function coach_company_dropdown_fix_find_string_field_value($entity, array $needles) {
  $field_manager = \Drupal::service('entity_field.manager');
  $defs = $field_manager->getFieldDefinitions($entity->getEntityTypeId(), $entity->bundle());

  foreach ($defs as $field_name => $def) {
    // Skip base fields that are commonly email/username/system.
    if (in_array($field_name, ['uid','uuid','langcode','mail','name','pass','status','created','changed'], TRUE)) {
      continue;
    }

    $lname = strtolower($field_name);
    $matched = FALSE;
    foreach ($needles as $n) {
      if (strpos($lname, $n) !== FALSE) {
        $matched = TRUE;
        break;
      }
    }
    if (!$matched) {
      continue;
    }

    if (!$entity->hasField($field_name) || $entity->get($field_name)->isEmpty()) {
      continue;
    }

    $item = $entity->get($field_name)->first();
    if (!$item) {
      continue;
    }

    // Try common properties.
    foreach (['value'] as $prop) {
      if (isset($item->$prop) && is_scalar($item->$prop)) {
        $val = trim((string) $item->$prop);
        if ($val !== '' && filter_var($val, FILTER_VALIDATE_EMAIL) === FALSE) {
          return $val;
        }
      }
    }
  }

  return '';
}

/**
 * Attach CSS only on /coach to fix exposed form overlap.
 */
function coach_company_dropdown_fix_page_attachments(array &$attachments) {
  $path = \Drupal::service('path.current')->getPath();
  if ($path === '/coach') {
    $attachments['#attached']['library'][] = 'coach_company_dropdown_fix/coach_coach_page';
  }
}

/**
 * Ensure the selected company value is applied to the correct Views exposed key.
 * Some views use field_company, some use field_company_target_id etc.
 */
function coach_company_dropdown_fix_exposed_validate(array &$form, \Drupal\Core\Form\FormStateInterface $form_state) {
  $view = $form_state->get('view');
  if (!$view) {
    return;
  }

  // Only on /coach view page.
  $display = $view->current_display;
  $path = $view->displayHandlers->get($display)->getOption('path');
  if ($path !== 'coach' && $path !== '/coach') {
    return;
  }

  // Find whichever company element exists on the form.
  $src_key = NULL;
  foreach (['field_company_target_id', 'field_company', 'company'] as $k) {
    if (isset($form[$k])) {
      $src_key = $k;
      break;
    }
  }
  if (!$src_key) {
    return;
  }

  $val = $form_state->getValue($src_key);

  // Normalize: select gives scalar; sometimes Views expects scalar string/int.
  if (is_array($val)) {
    $val = reset($val);
  }
  $val = (string) $val;

  // Copy to all possible keys so Views definitely receives it.
  foreach (['field_company_target_id', 'field_company', 'company'] as $k) {
    $form_state->setValue($k, $val);
  }

  // Also copy into user input (Views reads from user input too).
  $input = $form_state->getUserInput();
  foreach (['field_company_target_id', 'field_company', 'company'] as $k) {
    $input[$k] = $val;
  }
  $form_state->setUserInput($input);
}

/**
 * Force company filter to work by filtering users via Profile->field_company.
 */
function coach_company_dropdown_fix_views_query_alter(\Drupal\views\ViewExecutable $view, \Drupal\views\Plugin\views\query\QueryPluginBase $query) {
  // Only SQL views.
  if (!($query instanceof \Drupal\views\Plugin\views\query\Sql)) {
    return;
  }

  // Only on /coach display (avoid breaking other views).
  $display = $view->current_display;
  $path = $view->display_handler->getOption('path');
  if ($path !== 'coach' && $path !== '/coach') {
    return;
  }

  // Read selected company from exposed input / URL.
  $input = $view->getExposedInput();
  $cid = $input['field_company_target_id'] ?? $input['field_company'] ?? $input['company'] ?? NULL;
  if (is_array($cid)) {
    $cid = reset($cid);
  }
  $cid = (int) $cid;
  if ($cid <= 0) {
    return;
  }

  // Ensure base users table alias.
  $base_table = $view->storage->get('base_table'); // usually users_field_data
  $base_alias = $query->ensureTable($base_table);

  // Add WHERE EXISTS against profile + profile__field_company.
  // profile table PK is profile_id, field table uses entity_id = profile_id.
  $query->addWhereExpression(
    0,
    "EXISTS (
      SELECT 1
      FROM {profile} pr
      INNER JOIN {profile__field_company} fc ON fc.entity_id = pr.profile_id
      WHERE pr.uid = {$base_alias}.uid
        AND fc.field_company_target_id = :coach_company_cid
    )",
    [':coach_company_cid' => $cid]
  );
}
