<?php

use Drupal\Core\Form\FormStateInterface;
use Drupal\views\ViewExecutable;
use Drupal\views\Plugin\views\query\QueryPluginBase;

/**
 * /coach: Turn company exposed filter into a dropdown with company names
 * and make filtering reliable.
 */
function coach_company_dropdown_fix_form_views_exposed_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  $view = $form_state->get('view');
  if (!$view) {
    return;
  }

  // Only /coach display.
  $path = $view->display_handler->getOption('path');
  if ($path !== 'coach' && $path !== '/coach') {
    return;
  }

  // Attach CSS (layout fixes).
  $form['#attached']['library'][] = 'coach_company_dropdown_fix/coach_coach_page';

  // Force using this exposed key (your URL already uses it).
  $key = 'field_company_target_id';

  // If views uses a different element key, clone it into field_company_target_id.
  if (!isset($form[$key])) {
    foreach (['field_company', 'company'] as $alt) {
      if (isset($form[$alt]) && is_array($form[$alt])) {
        $form[$key] = $form[$alt];
        unset($form[$alt]);
        break;
      }
    }
  }

  if (!isset($form[$key]) || !is_array($form[$key])) {
    return;
  }

  // Build dropdown values ONLY from companies that are used by COACH users.
  $conn = \Drupal::database();
  $ids = $conn->query("
    SELECT DISTINCT fc.field_company_target_id
    FROM {profile__field_company} fc
    INNER JOIN {profile} pr ON pr.profile_id = fc.entity_id
    INNER JOIN {user__roles} ur ON ur.entity_id = pr.uid
    WHERE ur.roles_target_id = :coach_role
  ", [':coach_role' => 'coach'])->fetchCol();

  $ids = array_values(array_unique(array_filter(array_map('intval', $ids))));
  $options = ['' => t('- Any -')];

  if ($ids) {
    $companies = \Drupal::entityTypeManager()->getStorage('user')->loadMultiple($ids);
    foreach ($companies as $uid => $company_user) {
      $label = coach_company_dropdown_fix_get_company_label($company_user);
      $options[$uid] = $label ?: $company_user->getDisplayName();
    }

    // Sort labels, keep keys.
    $sorted = $options;
    unset($sorted['']);
    natcasesort($sorted);
    $options = ['' => t('- Any -')] + $sorted;
  }

  // Convert to dropdown and force HTML name.
  $form[$key]['#type'] = 'select';
  $form[$key]['#options'] = $options;
  $form[$key]['#size'] = 1;
  $form[$key]['#multiple'] = FALSE;
  $form[$key]['#name'] = 'field_company_target_id';

  // Prevent it becoming an autocomplete textbox.
  unset(
    $form[$key]['#autocomplete_route_name'],
    $form[$key]['#autocomplete_route_parameters'],
    $form[$key]['#selection_settings'],
    $form[$key]['#target_type'],
    $form[$key]['#process']
  );

  // Normalize on submit.
  $form['#validate'][] = 'coach_company_dropdown_fix_exposed_validate';
}

/**
 * Attach CSS only on /coach.
 */
function coach_company_dropdown_fix_page_attachments(array &$attachments) {
  $path = \Drupal::service('path.current')->getPath();
  if ($path === '/coach') {
    $attachments['#attached']['library'][] = 'coach_company_dropdown_fix/coach_coach_page';
  }
}

/**
 * Ensure exposed value is always in field_company_target_id (single key).
 */
function coach_company_dropdown_fix_exposed_validate(array &$form, FormStateInterface $form_state) {
  $view = $form_state->get('view');
  if (!$view) {
    return;
  }

  $path = $view->display_handler->getOption('path');
  if ($path !== 'coach' && $path !== '/coach') {
    return;
  }

  $val = $form_state->getValue('field_company_target_id');
  if (is_array($val)) {
    $val = reset($val);
  }
  $val = (string) $val;

  $form_state->setValue('field_company_target_id', $val);

  // Views reads user input (GET) a lot, so force it there too.
  $input = $form_state->getUserInput();
  $input['field_company_target_id'] = $val;
  $form_state->setUserInput($input);
}

/**
 * The IMPORTANT part:
 * Filter coaches reliably using uid IN (subquery).
 * This avoids broken joins/relationships in Views.
 */
function coach_company_dropdown_fix_views_query_alter(ViewExecutable $view, QueryPluginBase $query) {
  if (!($query instanceof \Drupal\views\Plugin\views\query\Sql)) {
    return;
  }

  $path = $view->display_handler->getOption('path');
  if ($path !== 'coach' && $path !== '/coach') {
    return;
  }

  $input = $view->getExposedInput();
  $cid = $input['field_company_target_id'] ?? NULL;
  if (is_array($cid)) {
    $cid = reset($cid);
  }
  $cid = (int) $cid;
  if ($cid <= 0) {
    return;
  }

  $base_table = $view->storage->get('base_table'); // usually users_field_data
  $base_alias = $query->ensureTable($base_table);

  $query->addWhereExpression(
    0,
    "{$base_alias}.uid IN (
      SELECT DISTINCT pr.uid
      FROM {profile} pr
      INNER JOIN {profile__field_company} fc ON fc.entity_id = pr.profile_id
      INNER JOIN {user__roles} ur ON ur.entity_id = pr.uid
      WHERE ur.roles_target_id = :coach_role
        AND fc.field_company_target_id = :cid
    )",
    [':coach_role' => 'coach', ':cid' => $cid]
  );
}

/**
 * Prefer company-name-ish fields, avoid emails.
 */
function coach_company_dropdown_fix_get_company_label($account) {
  $label = coach_company_dropdown_fix_find_string_field_value($account, ['company','organization','organisation','org','business','title','name']);
  if ($label) {
    return $label;
  }

  if (\Drupal::moduleHandler()->moduleExists('profile')) {
    $profiles = \Drupal::entityTypeManager()->getStorage('profile')->loadByProperties(['uid' => $account->id()]);
    foreach ($profiles as $profile) {
      $label = coach_company_dropdown_fix_find_string_field_value($profile, ['company','organization','organisation','org','business','title','name']);
      if ($label) {
        return $label;
      }
    }
  }

  return $account->getDisplayName();
}

function coach_company_dropdown_fix_find_string_field_value($entity, array $needles) {
  $field_manager = \Drupal::service('entity_field.manager');
  $defs = $field_manager->getFieldDefinitions($entity->getEntityTypeId(), $entity->bundle());

  foreach ($defs as $field_name => $def) {
    if (in_array($field_name, ['uid','uuid','langcode','mail','name','pass','status','created','changed'], TRUE)) {
      continue;
    }

    $lname = strtolower($field_name);
    $matched = FALSE;
    foreach ($needles as $n) {
      if (strpos($lname, $n) !== FALSE) {
        $matched = TRUE;
        break;
      }
    }
    if (!$matched) {
      continue;
    }

    if (!$entity->hasField($field_name) || $entity->get($field_name)->isEmpty()) {
      continue;
    }

    $item = $entity->get($field_name)->first();
    if ($item && isset($item->value)) {
      $val = trim((string) $item->value);
      if ($val !== '' && filter_var($val, FILTER_VALIDATE_EMAIL) === FALSE) {
        return $val;
      }
    }
  }

  return '';
}
