<?php

/**
 * Implements hook_mail().
 */
function coach_csv_import_mail($key, &$message, $params) {
  if ($key === 'coach_import') {
    $message['subject'] = $params['subject'] ?? 'Coach account updated';
    $body = $params['message'] ?? '';
    $message['body'] = is_array($body) ? $body : explode("\n", (string) $body);
  }
}
