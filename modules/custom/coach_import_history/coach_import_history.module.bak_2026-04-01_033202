<?php

/**
 * @file
 * Mail helpers for coach import history.
 */

use Symfony\Component\Mailer\Mailer;
use Symfony\Component\Mailer\Transport;
use Symfony\Component\Mime\Email;

/**
 * Implements hook_mail().
 */
function coach_import_history_mail($key, &$message, $params) {
  $attachments = [];
  if (!empty($params['attachments']) && is_array($params['attachments'])) {
    $attachments = $params['attachments'];
  }

  switch ($key) {
    case 'coach_import':
      $message['subject'] = !empty($params['subject']) ? $params['subject'] : 'Coach account created';

      $body = '';
      if (!empty($params['message']) && is_string($params['message'])) {
        $body = trim($params['message']);
      }
      elseif (!empty($params['body']) && is_string($params['body'])) {
        $body = trim($params['body']);
      }
      elseif (!empty($params['body']) && is_array($params['body'])) {
        $body = trim(implode("\n", array_filter($params['body'])));
      }

      if ($body === '') {
        $username = $params['username'] ?? '';
        $email = $params['email'] ?? '';
        $company_name = $params['company_name'] ?? '';

        $lines = [
          'Hello,',
          '',
          'Your coach account has been created.',
        ];

        if ($company_name !== '') {
          $lines[] = '';
          $lines[] = 'Selected company: ' . $company_name;
        }
        if ($username !== '') {
          $lines[] = '';
          $lines[] = 'Username: ' . $username;
        }
        if ($email !== '') {
          $lines[] = '';
          $lines[] = 'Email: ' . $email;
        }

        $body = implode("\n", $lines);
      }

      $message['body'] = [$body];
      if (!empty($attachments)) {
        $message['params']['attachments'] = $attachments;
        $message['attachments'] = $attachments;
      }
      break;

    case 'admin_coach_import_mail':
      $message['subject'] = !empty($params['subject']) ? $params['subject'] : 'Coach Import Notification';

      $body = '';
      if (!empty($params['message']) && is_string($params['message'])) {
        $body = trim($params['message']);
      }
      elseif (!empty($params['body']) && is_string($params['body'])) {
        $body = trim($params['body']);
      }
      elseif (!empty($params['body']) && is_array($params['body'])) {
        $body = trim(implode("\n", array_filter($params['body'])));
      }

      if ($body === '') {
        $company_name = $params['company_name'] ?? '';
        $body = 'Selected company: ' . ($company_name !== '' ? $company_name : 'N/A');
      }

      $message['body'] = [$body];
      if (!empty($attachments)) {
        $message['params']['attachments'] = $attachments;
        $message['attachments'] = $attachments;
      }
      break;
  }
}

/**
 * Sends e-mail with optional attachments using existing DSN config.
 */
function coach_import_history_send_direct_mail(string $to, string $subject, string $body, array $attachments = []): bool {
  try {
    $dsn = \Drupal::config('system.mail')->get('mailer_dsn');
    if (empty($dsn)) {
      \Drupal::logger('coach_import_history')->error('Direct mail failed: mailer_dsn is empty.');
      return FALSE;
    }

    $site_mail = \Drupal::config('system.site')->get('mail');
    if (empty($site_mail)) {
      $site_mail = ini_get('sendmail_from') ?: 'no-reply@example.com';
    }

    $site_name = \Drupal::config('system.site')->get('name') ?: 'Drupal';

    $email = (new Email())
      ->from(sprintf('%s <%s>', $site_name, $site_mail))
      ->to($to)
      ->subject($subject)
      ->text($body);

    foreach ($attachments as $attachment) {
      if (!empty($attachment['filepath']) && file_exists($attachment['filepath'])) {
        $email->attachFromPath(
          $attachment['filepath'],
          $attachment['filename'] ?? basename($attachment['filepath']),
          $attachment['filemime'] ?? null
        );
      }
    }

    $transport = Transport::fromDsn($dsn);
    $mailer = new Mailer($transport);
    $mailer->send($email);

    \Drupal::logger('coach_import_history')->notice('Direct mail sent to @to with @count attachment(s).', [
      '@to' => $to,
      '@count' => count($attachments),
    ]);

    return TRUE;
  }
  catch (\Throwable $e) {
    \Drupal::logger('coach_import_history')->error('Direct mail failed for @to: @msg', [
      '@to' => $to,
      '@msg' => $e->getMessage(),
    ]);
    return FALSE;
  }
}
