<?php

use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_form_alter().
 */
function company_dropdown_form_alter(&$form, FormStateInterface $form_state, $form_id) {

  // Get current path.
  $path = \Drupal::service('path.current')->getPath();

  // Run only on coach and employee pages.
  if ($path !== '/coach' && $path !== '/employee') {
    return;
  }

  // Ensure the company filter exists.
  if (!isset($form['field_company_target_id'])) {
    return;
  }

  // Default dropdown option.
  $options = [
    '' => '- Select -',
  ];

  // Query companies used in profiles.
  $query = \Drupal::database()->select('profile__field_company', 'fc');
  $query->join('profile', 'p', 'p.profile_id = fc.entity_id');
  $query->addField('fc', 'field_company_target_id');
  $query->isNotNull('fc.field_company_target_id');
  $query->distinct();

  $company_ids = $query->execute()->fetchCol();

  foreach ($company_ids as $company_id) {

    if (!$company_id) {
      continue;
    }

    // Load company profile.
    $profiles = \Drupal::entityTypeManager()
      ->getStorage('profile')
      ->loadByProperties([
        'uid' => $company_id,
        'type' => 'company'
      ]);

    if ($profiles) {

      $profile = reset($profiles);

      // Get company name field.
      if ($profile->hasField('field_company_name')) {
        $name = $profile->get('field_company_name')->value;
      }
      else {
        // Fallback to user display name.
        $user = \Drupal\user\Entity\User::load($company_id);
        $name = $user ? $user->getDisplayName() : $company_id;
      }

      $options[$company_id] = $name;
    }
  }

  // Convert to dropdown.
  $form['field_company_target_id']['#type'] = 'select';
  $form['field_company_target_id']['#options'] = $options;
  $form['field_company_target_id']['#empty_option'] = '- Select -';

  // FORCE dropdown instead of listbox.
  $form['field_company_target_id']['#size'] = 1;
  $form['field_company_target_id']['#multiple'] = FALSE;

  // Prevent autofocus.
  $form['field_company_target_id']['#attributes']['autofocus'] = FALSE;

  // Add styling class.
  $form['field_company_target_id']['#attributes']['class'][] = 'company-dropdown';

}