<?php

use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_form_views_exposed_form_alter().
 */
function company_dropdown_form_views_exposed_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  // Run only on /employee page (your listing).
  $path = \Drupal::requestStack()->getCurrentRequest()->getPathInfo();
  if ($path !== '/employee') {
    return;
  }

  // Find the exposed element for field_company (it may be field_company, field_company_target_id, etc).
  $key = _company_dropdown_find_element_key($form);
  if (!$key) {
    return;
  }

  $options = _company_dropdown_get_company_options();
  if (count($options) <= 1) {
    return;
  }

  // Convert to normal dropdown.
  $current = $form[$key]['#default_value'] ?? '';
  $form[$key]['#type'] = 'select';
  $form[$key]['#options'] = $options;
  $form[$key]['#default_value'] = $current;
  $form[$key]['#empty_option'] = '- Any -';
  $form[]['#size'] = 1;
  $form[]['#attributes']['onchange'] = 'this.form.submit();';
}

/**
 * Find the Company exposed filter element key in the form.
 */
function _company_dropdown_find_element_key(array $form): ?string {
  foreach ($form as $k => $v) {
    if (!is_array($v)) {
      continue;
    }
    // Look for keys/names that contain field_company.
    $name = $v['#name'] ?? '';
    if (strpos((string) $k, 'field_company') !== FALSE || strpos((string) $name, 'field_company') !== FALSE) {
      // Must be an input element.
      if (isset($v['#type']) && in_array($v['#type'], ['textfield', 'select', 'autocomplete_deluxe'], TRUE)) {
        return (string) $k;
      }
      // Sometimes #type is missing until later, still return the likely element.
      if (isset($v['#title']) || isset($v['#name'])) {
        return (string) $k;
      }
    }
  }
  return NULL;
}

/**
 * Build company dropdown options.
 * Source: distinct company user IDs referenced from employee profiles (profile__field_company).
 * Label: company name field/profile if available, else display name.
 */
function _company_dropdown_get_company_options(): array {
  $db = \Drupal::database();
  $schema = $db->schema();

  // Your system stores company reference on profile.
  $table = 'profile__field_company';
  if (!$schema->tableExists($table)) {
    // Fallback if stored on user.
    $table = 'user__field_company';
    if (!$schema->tableExists($table)) {
      return ['' => '- Any -'];
    }
  }

  // Detect the correct target_id column.
  $cols = $db->query("SHOW COLUMNS FROM {$table}")->fetchCol();
  $target_col = NULL;
  foreach ($cols as $c) {
    if (strpos($c, 'field_company_') === 0 && substr($c, -10) === '_target_id') {
      $target_col = $c;
      break;
    }
  }
  if (!$target_col) {
    return ['' => '- Any -'];
  }

  // Get distinct company user ids.
  $ids = $db->select($table, 't')
    ->distinct()
    ->fields('t', [$target_col])
    ->condition($target_col, 0, '>')
    ->execute()
    ->fetchCol();

  $ids = array_values(array_unique(array_map('intval', $ids)));
  if (!$ids) {
    return ['' => '- Any -'];
  }

  // Load users and build labels.
  $users = \Drupal::entityTypeManager()->getStorage('user')->loadMultiple($ids);

  $options = ['' => '- Any -'];
  foreach ($users as $uid => $user) {
    $label = _company_dropdown_pretty_company_name($user);
    if ($label !== '') {
      $options[(string) $uid] = $label;
    }
  }

  // Sort by label.
  $head = ['' => '- Any -'];
  $rest = $options;
  unset($rest['']);
  asort($rest, SORT_NATURAL | SORT_FLAG_CASE);
  return $head + $rest;
}

/**
 * Get company name for a company user.
 * Tries common fields and company profile fields. Falls back to display name.
 */
function _company_dropdown_pretty_company_name(\Drupal\user\UserInterface $user): string {
  // Try common "company name" fields on the user.
  $candidates = [
    'field_company_name',
    'field_name',
    'field_title',
    'field_organization',
    'field_organisation',
  ];
  foreach ($candidates as $f) {
    if ($user->hasField($f) && !$user->get($f)->isEmpty()) {
      $val = (string) ($user->get($f)->value ?? '');
      $val = trim($val);
      if ($val !== '') {
        return $val;
      }
      if ($user->get($f)->entity) {
        $lbl = trim((string) $user->get($f)->entity->label());
        if ($lbl !== '') {
          return $lbl;
        }
      }
    }
  }

  // Try company profile attached to the user (if Profile module used for company data).
  if (\Drupal::moduleHandler()->moduleExists('profile')) {
    try {
      $profiles = \Drupal::entityTypeManager()->getStorage('profile')->loadByProperties(['uid' => $user->id()]);
      if ($profiles) {
        // Prefer a profile bundle named 'company' if it exists.
        usort($profiles, fn($a, $b) => ($a->bundle() === 'company') ? -1 : 1);

        $pf_candidates = [
          'field_company_name',
          'field_name',
          'field_title',
          'field_company',
        ];
        foreach ($profiles as $p) {
          foreach ($pf_candidates as $f) {
            if ($p->hasField($f) && !$p->get($f)->isEmpty()) {
              $val = (string) ($p->get($f)->value ?? '');
              $val = trim($val);
              if ($val !== '') {
                return $val;
              }
              if ($p->get($f)->entity) {
                $lbl = trim((string) $p->get($f)->entity->label());
                if ($lbl !== '') {
                  return $lbl;
                }
              }
            }
          }
        }
      }
    }
    catch (\Throwable $e) {
      // Ignore and fallback.
    }
  }

  // Fallback (your old value = email/username).
  return trim((string) $user->getDisplayName());
}
