<?php

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Database\Database;

function company_dropdown_filter_form_views_exposed_form_alter__DISABLED(array &$form, FormStateInterface $form_state, $form_id) {

  // ---- Detect view + display reliably (form_state OR #info OR #id) ----
  $view = $form_state->get('view');
  $display_id = $form_state->get('display_id');

  if (!$view && isset($form['#info']['view'])) {
    $view = $form['#info']['view'];
  }
  if (!$display_id && isset($form['#info']['display_id'])) {
    $display_id = $form['#info']['display_id'];
  }

  $view_id = is_object($view) && method_exists($view, 'id') ? $view->id() : '';

  // Fallback: parse from form HTML id like "views-exposed-form-company-page-2"
  if (!$view_id && !empty($form['#id']) && is_string($form['#id'])) {
    $id = $form['#id'];
    if (strpos($id, 'views-exposed-form-') === 0) {
      $rest = substr($id, strlen('views-exposed-form-'));
      $parts = explode('-', $rest);
      if (count($parts) >= 2) {
        $view_id = array_shift($parts);
        $display_id = str_replace('-', '_', implode('-', $parts)); // page-2 -> page_2
      }
    }
  }

  // ---- ONLY run on your view ----
  // Your screenshot URL: /admin/structure/views/view/company/edit/page_2  => view machine name "company"
  if ($view_id !== 'company') {
    return;
  }

  // Debug just for your view
  \Drupal::logger('company_dropdown_filter')->notice('ON COACH/EMP VIEW: view=@v display=@d formid=@fid htmlid=@hid', [
    '@v' => $view_id,
    '@d' => (string) $display_id,
    '@fid' => (string) $form_id,
    '@hid' => (string) ($form['#id'] ?? ''),
  ]);

  // ---- Find the exposed company element key ----
  $company_key = NULL;
  foreach ($form as $k => $el) {
    if (!is_array($el)) continue;
    if (strpos((string)$k, 'field_company') !== FALSE) {
      if (isset($el['#type'])) {
        $company_key = $k;
        break;
      }
    }
  }

  if (!$company_key) {
    // Last chance: look by title
    foreach ($form as $k => $el) {
      if (!is_array($el)) continue;
      $title = (string) ($el['#title'] ?? '');
      if (stripos($title, 'Company') !== FALSE && isset($el['#type'])) {
        $company_key = $k;
        break;
      }
    }
  }

  if (!$company_key) {
    \Drupal::logger('company_dropdown_filter')->error('Company key NOT found. Form keys: @keys', [
      '@keys' => implode(',', array_keys($form)),
    ]);
    return;
  }

  \Drupal::logger('company_dropdown_filter')->notice('Company key found: @k current_type=@t', [
    '@k' => $company_key,
    '@t' => (string) ($form[$company_key]['#type'] ?? ''),
  ]);

  // ---- Build dropdown options: value = company user uid, label = company profile label (company name) ----
  $options = ['' => '- Any -'];

  try {
    $db = Database::getConnection();

    // Try best-guess company profile type
    $types = $db->query("SELECT DISTINCT type FROM profile")->fetchCol();
    $company_type = NULL;
    foreach (['company', 'company_profile', 'companyprofile', 'Company'] as $t) {
      if (in_array($t, $types, TRUE)) { $company_type = $t; break; }
    }

    $q = $db->select('profile__field_company', 'pfc');
    $q->addField('pfc', 'field_company_target_id', 'uid');
    $q->condition('pfc.deleted', 0);
    $q->isNotNull('pfc.field_company_target_id');
    $q->distinct();

    // Join company profile to get company name
    $q->leftJoin('profile', 'cp', 'cp.uid = pfc.field_company_target_id AND cp.deleted = 0' . ($company_type ? " AND cp.type = :ctype" : ""));
    if ($company_type) {
      $q->addTag('ctype_tag');
      $q->addMetaData('ctype', $company_type);
      $q->addExpression('cp.label', 'label');
      $q->addExpression(':ctype', 'ctype_expr'); // keeps parameter alive
      $q->addWhereExpression(0, '1=1', [':ctype' => $company_type]);
    }
    else {
      $q->addExpression('cp.label', 'label');
    }

    // Also join user table as fallback (if label empty)
    $q->leftJoin('users_field_data', 'u', 'u.uid = pfc.field_company_target_id');
    $q->addExpression("COALESCE(NULLIF(cp.label,''), NULLIF(u.name,''), u.mail)", 'final_label');

    $q->orderBy('final_label', 'ASC');

    foreach ($q->execute() as $row) {
      $uid = (string) $row->uid;
      $label = trim((string) $row->final_label);
      if ($uid !== '' && $label !== '') {
        $options[$uid] = $label;
      }
    }

    \Drupal::logger('company_dropdown_filter')->notice('Options count: @n', ['@n' => count($options)]);
  }
  catch (\Throwable $e) {
    \Drupal::logger('company_dropdown_filter')->error('DB error: @m', ['@m' => $e->getMessage()]);
    return;
  }

  // ---- Force the exposed element to be a SELECT ----
  $default = $form_state->getUserInput()[$company_key] ?? '';
  $form[$company_key]['#type'] = 'select';
  $form[$company_key]['#title'] = 'Company';
  $form[$company_key]['#options'] = $options;
  $form[$company_key]['#default_value'] = $default;
  $form[$company_key]['#size'] = 1;
  $form[$company_key]['#validated'] = TRUE;

  \Drupal::logger('company_dropdown_filter')->notice('Dropdown applied successfully.');
}
