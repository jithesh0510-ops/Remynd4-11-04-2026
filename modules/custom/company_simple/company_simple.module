<?php

use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_form_views_exposed_form_alter().
 */
function company_simple_form_views_exposed_form_alter__DISABLED(array &$form, FormStateInterface $form_state) {
  $form["#attached"]["library"][] = "company_simple/exposed_fix";
  // Only for coach listing.
  if (\Drupal::request()->getPathInfo() !== '/coach') {
    return;
  }

  // This MUST match the Views exposed filter identifier.
  $key = 'field_company_target_id';
  if (!isset($form[$key])) {
    return;
  }

  // Collect distinct company user IDs used in profile__field_company.
  $uids = \Drupal::database()
    ->select('profile__field_company', 'pfc')
    ->fields('pfc', ['field_company_target_id'])
    ->condition('pfc.deleted', 0)
    ->condition('pfc.field_company_target_id', 0, '>')
    ->distinct()
    ->execute()
    ->fetchCol();

  $uids = array_values(array_unique(array_map('intval', $uids)));

  // If none, still show a select.
  if (empty($uids)) {
    $form[$key]['#type'] = 'select';
    $form[$key]['#options'] = ['' => '- Any -'];
    $form[$key]['#size'] = 1;
    return;
  }

  // Prefer company profile field_company_name for company profiles owned by those uids.
  $labels = [];

  $pids = \Drupal::entityQuery('profile')
    ->accessCheck(FALSE)
    ->condition('type', 'company')
    ->condition('uid', $uids, 'IN')
    ->execute();

  if (!empty($pids)) {
    $profiles = \Drupal::entityTypeManager()->getStorage('profile')->loadMultiple($pids);
    foreach ($profiles as $profile) {
      $uid = (int) $profile->getOwnerId();
      if ($uid && $profile->hasField('field_company_name') && !$profile->get('field_company_name')->isEmpty()) {
        $labels[$uid] = trim((string) $profile->get('field_company_name')->value);
      }
    }
  }

  // Fallback to username for missing labels.
  $missing = array_diff($uids, array_keys($labels));
  if (!empty($missing)) {
    $users = \Drupal::entityTypeManager()->getStorage('user')->loadMultiple($missing);
    foreach ($users as $uid => $user) {
      $labels[(int) $uid] = trim((string) $user->label());
    }
  }

  // Build options UID => label.
  $options = ['' => '- Any -'];
  foreach ($labels as $uid => $label) {
    if ($label !== '') {
      $options[(string) $uid] = $label;
    }
  }

  // Sort by label but keep Any on top.
  $any = $options['']; unset($options['']);
  natcasesort($options);
  $options = ['' => $any] + $options;

  // Force select UI.
  $form[$key]['#type'] = 'select';
  $form[$key]['#options'] = $options;
  $form[$key]['#multiple'] = FALSE;
  $form[$key]['#size'] = 1;

  // Preserve selected value after submit.
  $selected = \Drupal::request()->query->get($key);
  if ($selected !== NULL && $selected !== '') {
    $form[$key]['#default_value'] = (string) $selected;
  }
}

/**
 * Extra: ensure exposed form submits correctly via GET.
 */
function company_simple_form_views_exposed_form_alter__DISABLED__submit_fix(array &$form, FormStateInterface $form_state) {
  if (\Drupal::request()->getPathInfo() !== '/coach') {
    return;
  }
  // Force GET.
  $form['#method'] = 'get';
  // Ensure actions exist.
  if (isset($form['actions']['submit'])) {
    $form['actions']['submit']['#value'] = t('Search');
  }
}


/**
 * Implements hook_page_attachments().
 */
function company_simple_page_attachments(array &$attachments) {
  // Attach only on /coach page.
  if (\Drupal::request()->getPathInfo() === '/coach') {
    $attachments['#attached']['library'][] = 'company_simple/coach_page_polish';
  }
}
