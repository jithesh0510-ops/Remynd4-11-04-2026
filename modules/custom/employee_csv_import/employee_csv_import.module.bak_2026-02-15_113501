<?php

/**
 * Implements hook_mail().
 */
function employee_csv_import_mail($key, &$message, $params) {
  switch ($key) {
    case 'employee_import':
      $message['subject'] = $params['subject'] ?? 'Employee account updated';
      $body = $params['message'] ?? '';
      $message['body'] = is_array($body) ? $body : [$body];
      break;
  }
}
