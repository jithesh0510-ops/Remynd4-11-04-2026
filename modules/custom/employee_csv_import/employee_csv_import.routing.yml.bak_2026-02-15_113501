employee_csv_import.form:
  path: '/employee/importcsv'
  defaults:
    _form: '\Drupal\employee_csv_import\Form\EmployeeImportForm'
    _title: 'Import/Update employee'
  requirements:
    _permission: 'administer users'

employee_csv_import.download_sample:
  path: '/employee/importcsv/sample'
  defaults:
    _controller: '\Drupal\employee_csv_import\Controller\EmployeeCsvController::downloadSample'
  requirements:
    _permission: 'administer users'

employee_csv_import.download_key:
  path: '/employee/importcsv/key'
  defaults:
    _controller: '\Drupal\employee_csv_import\Controller\EmployeeCsvController::downloadKey'
  requirements:
    _permission: 'administer users'
