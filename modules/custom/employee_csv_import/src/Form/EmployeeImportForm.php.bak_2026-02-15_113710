<?php

namespace Drupal\employee_csv_import\Form;

use Drupal\Core\Form\FormBase;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;
use Drupal\user\Entity\User;

class EmployeeImportForm extends FormBase {

  public function getFormId(): string {
    return 'employee_csv_import_form';
  }

  public function buildForm(array $form, FormStateInterface $form_state): array {
    $form['company_id'] = [
      '#type' => 'select',
      '#title' => $this->t('Company Name'),
      '#options' => $this->loadCompanyOptions(),
      '#required' => TRUE,
    ];

    $form['csv_file'] = [
      '#type' => 'managed_file',
      '#title' => $this->t('Select File'),
      '#upload_location' => 'public://employee_import/',
      '#upload_validators' => [
        'file_validate_extensions' => ['csv'],
      ],
      '#required' => TRUE,
      '#description' => $this->t('Upload a CSV file. Required column: email (mail also accepted). Optional: first_name, last_name, name.'),
    ];

    $form['send_email'] = [
      '#type' => 'checkbox',
      '#title' => $this->t('Send an email'),
      '#default_value' => 0,
    ];

    $form['actions'] = ['#type' => 'actions'];

    $form['actions']['download_key'] = [
      '#type' => 'link',
      '#title' => $this->t('Download employee Key'),
      '#url' => Url::fromRoute('employee_csv_import.download_key'),
      '#attributes' => ['class' => ['button']],
    ];

    $form['actions']['download_sample'] = [
      '#type' => 'link',
      '#title' => $this->t('Download Sample'),
      '#url' => Url::fromRoute('employee_csv_import.download_sample'),
      '#attributes' => ['class' => ['button']],
    ];

    $form['actions']['cancel'] = [
      '#type' => 'link',
      '#title' => $this->t('Cancel'),
      '#url' => Url::fromUserInput('/employee'),
      '#attributes' => ['class' => ['button']],
    ];

    $form['actions']['submit'] = [
      '#type' => 'submit',
      '#value' => $this->t('Upload/Update employee'),
      '#button_type' => 'primary',
    ];

    return $form;
  }

  public function submitForm(array &$form, FormStateInterface $form_state): void {
    $company_id = (int) $form_state->getValue('company_id');
    $send_email = (bool) $form_state->getValue('send_email');

    $fids = $form_state->getValue('csv_file');
    $fid = is_array($fids) && !empty($fids) ? (int) $fids[0] : 0;
    if (!$fid) {
      $this->messenger()->addError($this->t('No CSV uploaded.'));
      return;
    }

    $file = \Drupal::entityTypeManager()->getStorage('file')->load($fid);
    $uri = $file ? $file->getFileUri() : '';
    $path = $uri ? \Drupal::service('file_system')->realpath($uri) : '';
    if (!$path || !is_readable($path)) {
      $this->messenger()->addError($this->t('Uploaded CSV file is not readable.'));
      return;
    }

    $rows = $this->readCsv($path);
    if (!$rows) {
      $this->messenger()->addError($this->t('CSV is empty.'));
      return;
    }

    $created = 0; $updated = 0; $errors = 0;

    foreach ($rows as $i => $row) {
      $email = trim((string) ($row['email'] ?? $row['mail'] ?? ''));
      if (!$email) { $errors++; continue; }

      $first = trim((string) ($row['first_name'] ?? ''));
      $last  = trim((string) ($row['last_name'] ?? ''));
      $name  = trim((string) ($row['name'] ?? ''));

      $account = user_load_by_mail($email);
      $is_new = FALSE;

      if (!$account) {
        $is_new = TRUE;
        $account = User::create([
          'name' => $email,
          'mail' => $email,
          'status' => 1,
        ]);
        $account->enforceIsNew();
      }

      if (!$account->hasRole('employee')) {
        $account->addRole('employee');
      }

      // Best-effort: attach company id to profile field if it exists.
      $this->setCompanyOnProfile((int) $account->id(), $company_id);

      // Optional: set display name fields if your site uses them (safe no-op if fields missing).
      $this->setIfFieldExists($account, 'field_first_name', $first ?: NULL);
      $this->setIfFieldExists($account, 'field_last_name', $last ?: NULL);
      $this->setIfFieldExists($account, 'field_name', $name ?: NULL);

      $account->save();

      if ($is_new) $created++; else $updated++;

      if ($send_email) {
        $this->sendSimpleMail($email, $account->getAccountName());
      }
    }

    $this->messenger()->addStatus($this->t('Done. Created: @c, Updated: @u, Errors: @e', [
      '@c' => $created, '@u' => $updated, '@e' => $errors,
    ]));

    $form_state->setRedirectUrl(Url::fromUserInput('/employee'));
  }

  private function readCsv(string $path): array {
    $out = [];
    if (($h = fopen($path, 'r')) === FALSE) return $out;

    $header = fgetcsv($h);
    if (!$header) { fclose($h); return $out; }

    $header = array_map(fn($v) => strtolower(trim((string) $v)), $header);

    while (($data = fgetcsv($h)) !== FALSE) {
      if (!array_filter($data, fn($v) => trim((string)$v) !== '')) continue;
      $row = [];
      foreach ($header as $idx => $key) {
        $row[$key] = $data[$idx] ?? '';
      }
      $out[] = $row;
    }
    fclose($h);
    return $out;
  }

  private function loadCompanyOptions(): array {
    // Same logic as coach: gather company IDs from profile_field_company table and resolve labels.
    $opts = ['' => $this->t('- Select -')];

    try {
      $ids = \Drupal::database()->query("
        SELECT DISTINCT field_company_target_id AS cid
        FROM profile_field_company
        WHERE field_company_target_id IS NOT NULL
      ")->fetchCol();
    }
    catch (\Throwable $e) {
      return $opts;
    }

    $ids = array_values(array_unique(array_filter(array_map('intval', $ids))));
    if (!$ids) return $opts;

    $labels = [];
    foreach ($ids as $cid) {
      $labels[$cid] = $this->resolveCompanyLabel($cid);
    }

    asort($labels, SORT_NATURAL | SORT_FLAG_CASE);

    foreach ($labels as $cid => $label) {
      $opts[$cid] = $label;
    }

    return $opts;
  }

  private function resolveCompanyLabel(int $cid): string {
    // 1) taxonomy term
    try {
      $term = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($cid);
      if ($term && method_exists($term, 'label')) {
        $l = (string) $term->label();
        if ($l !== '') return $l;
      }
    } catch (\Throwable $e) {}

    // 2) node title
    try {
      $node = \Drupal::entityTypeManager()->getStorage('node')->load($cid);
      if ($node && method_exists($node, 'label')) {
        $l = (string) $node->label();
        if ($l !== '') return $l;
      }
    } catch (\Throwable $e) {}

    // 3) profile label fields on "company user/profile" (best effort)
    try {
      $profiles = \Drupal::entityTypeManager()->getStorage('profile')->loadByProperties(['uid' => $cid]);
      if ($profiles) {
        $p = reset($profiles);
        foreach (['field_company_name','field_business_name','field_organization','field_org_name','field_name'] as $fn) {
          if ($p->hasField($fn) && !$p->get($fn)->isEmpty()) {
            $l = (string) $p->get($fn)->value;
            if ($l !== '') return $l;
          }
        }
      }
    } catch (\Throwable $e) {}

    return "Company #{$cid}";
  }

  private function setCompanyOnProfile(int $uid, int $company_id): void {
    try {
      $storage = \Drupal::entityTypeManager()->getStorage('profile');
      $profiles = $storage->loadByProperties(['uid' => $uid]);
      $profile = $profiles ? reset($profiles) : NULL;

      if (!$profile) {
        // Try default profile type name "profile" (safe). If your site uses another type, it will just skip.
        $profile = $storage->create(['type' => 'profile', 'uid' => $uid]);
      }

      if ($profile && $profile->hasField('field_company') && !$company_id === 0) {
        $profile->set('field_company', $company_id);
        $profile->save();
      }
    } catch (\Throwable $e) {
      // ignore
    }
  }

  private function setIfFieldExists(User $user, string $field, $value): void {
    try {
      if ($value === NULL || $value === '') return;
      if ($user->hasField($field)) {
        $user->set($field, $value);
      }
    } catch (\Throwable $e) {}
  }

  private function sendSimpleMail(string $to, string $username): void {
    try {
      $params = [
        'subject' => 'Employee account updated',
        'body' => [
          "Hello {$username},",
          "",
          "Your employee account has been created/updated.",
          "",
          "Thanks,",
        ],
      ];
      \Drupal::service('plugin.manager.mail')->mail(
        'employee_csv_import',
        'employee_import',
        $to,
        \Drupal::languageManager()->getDefaultLanguage()->getId(),
        $params
      );
    } catch (\Throwable $e) {
      // ignore mail failures
    }
  }
}
