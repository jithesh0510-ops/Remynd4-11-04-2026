<?php

/**
 * Implements hook_mail().
 */
function employee_import_history_mail($key, &$message, $params) {
  switch ($key) {
    case 'employee_import':
      $message['subject'] = !empty($params['subject']) ? (string) $params['subject'] : 'Employee account created';

      $body = '';
      if (!empty($params['message']) && is_string($params['message'])) {
        $body = trim($params['message']);
      }
      elseif (!empty($params['body']) && is_string($params['body'])) {
        $body = trim($params['body']);
      }
      elseif (!empty($params['body']) && is_array($params['body'])) {
        $body = trim(implode("\n", array_filter($params['body'])));
      }

      if ($body === '') {
        $username = !empty($params['username']) ? (string) $params['username'] : '';
        $email = !empty($params['email']) ? (string) $params['email'] : '';
        $company_name = !empty($params['company_name']) ? (string) $params['company_name'] : '';

        $lines = [
          'Hello,',
          '',
          'Your employee account has been created.',
        ];

        if ($company_name !== '') {
          $lines[] = '';
          $lines[] = 'Selected company: ' . $company_name;
        }

        if ($username !== '') {
          $lines[] = '';
          $lines[] = 'Username: ' . $username;
        }

        if ($email !== '') {
          $lines[] = '';
          $lines[] = 'Email: ' . $email;
        }

        $body = implode("\n", $lines);
      }

      $message['body'] = [$body];

      if (!empty($message['from'])) {
        $message['headers']['Reply-to'] = $message['from'];
      }
      break;

    case 'admin_employee_import_mail':
      $message['subject'] = !empty($params['subject']) ? (string) $params['subject'] : 'Employee Import Notification';

      $body = '';
      if (!empty($params['message']) && is_string($params['message'])) {
        $body = trim($params['message']);
      }
      elseif (!empty($params['body']) && is_string($params['body'])) {
        $body = trim($params['body']);
      }
      elseif (!empty($params['body']) && is_array($params['body'])) {
        $body = trim(implode("\n", array_filter($params['body'])));
      }

      if ($body === '') {
        $company_name = !empty($params['company_name']) ? (string) $params['company_name'] : 'N/A';
        $body = 'Selected company: ' . $company_name;
      }

      $message['body'] = [$body];

      if (!empty($message['from'])) {
        $message['headers']['Reply-to'] = $message['from'];
      }
      break;
  }
}
