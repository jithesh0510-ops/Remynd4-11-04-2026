<style>
  body.path-user-login {
    margin: 0;
    background: #f3f5f7;
    font-family: Arial, sans-serif;
  }

  body.path-user-login .tabs,
  body.path-user-login .page-title,
  body.path-user-login .breadcrumb,
  body.path-user-login .messages,
  body.path-user-login header,
  body.path-user-login footer,
  body.path-user-login .region-sidebar-first,
  body.path-user-login .region-sidebar-second {
    display: none !important;
  }

  .remynd-login-page {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 430px;
    grid-template-rows: 108px 1fr;
    gap: 18px;
    background: #f3f5f7;
  }

  .remynd-login-header {
    grid-column: 1 / 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 24px;
    border-bottom: 1px solid #d9d9d9;
    background: #f3f5f7;
  }

  .remynd-login-brand img {
    max-width: 290px;
    height: auto;
    display: block;
  }

  .remynd-login-title {
    text-align: right;
    color: #0c7f88;
    font-size: 22px;
    font-weight: 700;
    line-height: 1.35;
  }

  .remynd-login-title span {
    color: #d3751f;
    display: block;
    margin-top: 6px;
  }

  .remynd-login-left {
    margin: 22px 0 24px 18px;
    background: #fff;
    border: 1px solid #d8d8d8;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(0,0,0,.04);
  }

  .remynd-login-left-head {
    background: #0f8f8f;
    color: #fff;
    font-size: 18px;
    font-weight: 700;
    padding: 16px 22px;
  }

  .remynd-login-left-body {
    padding: 22px;
    color: #1e2d3a;
    font-size: 16px;
    line-height: 1.8;
  }

  .remynd-login-left-body p {
    margin: 0 0 16px;
  }

  .remynd-login-right {
    margin: 22px 18px 24px 0;
  }

  .remynd-login-card {
    background: #fff;
    border: 1px solid #d8d8d8;
    border-radius: 18px;
    box-shadow: 0 2px 10px rgba(0,0,0,.05);
    padding: 84px 28px 24px;
    position: relative;
  }

  .remynd-login-card::before {
    content: "";
    position: absolute;
    top: -38px;
    left: 50%;
    transform: translateX(-50%);
    width: 108px;
    height: 108px;
    border-radius: 50%;
    background: #fff url('/sites/default/files/logo-email.png') center center / 82px auto no-repeat;
    border: 2px solid #2aa3a3;
    box-shadow: 0 4px 14px rgba(0,0,0,.08);
  }

  .remynd-login-card .form-item {
    margin-bottom: 18px;
  }

  .remynd-login-card label {
    display: inline-block;
    margin-bottom: 8px;
    font-size: 14px;
    font-weight: 600;
    color: #20394a;
  }

  .remynd-login-card input[type="email"],
  .remynd-login-card input[type="password"],
  .remynd-login-card input[type="text"] {
    width: 100%;
    height: 48px;
    border: 1px solid #d7dee4;
    border-radius: 8px;
    background: #fff;
    padding: 0 14px;
    font-size: 15px;
    box-sizing: border-box;
  }

  .remynd-login-card input::placeholder {
    color: #90a08c;
    opacity: 1;
  }

  .remynd-login-card input:focus {
    outline: none;
    border-color: #0f8f8f;
    box-shadow: 0 0 0 3px rgba(15,143,143,.10);
  }

  .remynd-login-card .form-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    margin-top: 8px;
  }

  .remynd-login-card .form-actions input {
    min-height: 44px;
    border-radius: 8px;
    padding: 0 22px;
    font-size: 15px;
    font-weight: 700;
    border: 0;
    cursor: pointer;
  }

  .remynd-login-card .form-actions input:first-child {
    background: #0f8f8f;
    color: #fff;
    min-width: 110px;
  }

  .remynd-login-card .form-actions input:not(:first-child) {
    background: #6f7b88;
    color: #fff;
  }

  .remynd-login-card .otp-current-email {
    background: #f2fbfb;
    border: 1px solid #d2ecec;
    border-radius: 8px;
    padding: 12px 14px;
    color: #18485d;
    margin-bottom: 16px;
    font-size: 14px;
  }

  .remynd-login-help {
    margin-top: 14px;
    color: #3e6fd1;
    font-size: 13px;
  }

  @media (max-width: 991px) {
    .remynd-login-page {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
    }

    .remynd-login-header {
      grid-column: 1 / 2;
      flex-direction: column;
      align-items: center;
      gap: 14px;
      text-align: center;
    }

    .remynd-login-title {
      text-align: center;
    }

    .remynd-login-left,
    .remynd-login-right {
      margin: 0 14px 18px;
    }
  }
</style>

<div class="remynd-login-page">
  <div class="remynd-login-header">
    <div class="remynd-login-brand">
      <img src="/sites/default/files/logo-email.png" alt="Remynd4">
    </div>
    <div class="remynd-login-title">
      Secure Login Portal
      <span>Remynd4 Member Access</span>
    </div>
  </div>

  <div class="remynd-login-left">
    <div class="remynd-login-left-head">Dear Remynd4 Users !!</div>
    <div class="remynd-login-left-body">
      <p>Welcome to the Remynd4 secure login portal.</p>
      <p>Use your registered email, password and one-time OTP to continue securely.</p>
      <p>If you face any issue while signing in, please contact the administrator.</p>
    </div>
  </div>

  <div class="remynd-login-right">
    <div class="remynd-login-card">
      {{ page.content }}
      <div class="remynd-login-help"><a href="/user/password">Forgot Password ?</a></div>
    </div>
  </div>
</div>
